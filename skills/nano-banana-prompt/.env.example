# imgeditor.co Nano Banana API（https://imgeditor.co/ja/api）
# このファイルをコピーして .env にリネームし、nb_sk_... を入れてください。.env は git に含めません。

NANO_BANANA_API_KEY=nb_sk_replace_with_your_key

# SSL エラーになる場合のみ（推奨は certifi のインストール）
# NANO_BANANA_SSL_VERIFY=0

# Supabase 参照画像を --supabase_object_path で使うとき（任意）
# SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
# SUPABASE_REFERENCE_BUCKET=character-refs
